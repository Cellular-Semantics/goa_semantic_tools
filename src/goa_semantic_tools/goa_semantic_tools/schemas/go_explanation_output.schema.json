{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Cellular-Semantics/goa_semantic_tools/schemas/go_explanation_output.schema.json",
  "title": "GO Enrichment with Explanations",
  "description": "GO enrichment results combined with LLM-generated natural language explanations",
  "type": "object",
  "properties": {
    "explanations": {
      "type": "array",
      "description": "Natural language explanations for each cluster",
      "items": {
        "type": "object",
        "properties": {
          "root_term": {
            "type": "object",
            "description": "Root GO term for this cluster",
            "properties": {
              "go_id": {
                "type": "string",
                "description": "GO identifier"
              },
              "name": {
                "type": "string",
                "description": "GO term name"
              },
              "namespace": {
                "type": "string",
                "description": "GO namespace"
              },
              "fdr": {
                "type": "number",
                "description": "FDR-adjusted p-value"
              },
              "fold_enrichment": {
                "type": "number",
                "description": "Fold enrichment"
              },
              "study_count": {
                "type": "integer",
                "minimum": 0,
                "description": "Number of study genes in this term"
              },
              "study_genes": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Study genes associated with this term"
              }
            },
            "required": [
              "go_id",
              "name",
              "namespace",
              "fdr",
              "fold_enrichment",
              "study_count",
              "study_genes"
            ],
            "additionalProperties": false
          },
          "explanation": {
            "type": "string",
            "minLength": 100,
            "description": "Detailed explanation of WHY genes cluster, WHAT processes are enriched, and HOW evidence supports this."
          }
        },
        "required": ["root_term", "explanation"],
        "additionalProperties": false
      }
    },
    "overall_summary": {
      "type": "string",
      "minLength": 200,
      "description": "Overall interpretation synthesizing all clusters into a coherent biological narrative"
    }
  },
  "required": ["explanations", "overall_summary"],
  "additionalProperties": false
}
